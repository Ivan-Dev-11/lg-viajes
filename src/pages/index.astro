---
import Layout from '../layouts/Layout.astro';
---

<Layout title="LG Viajes | Traslados Seguros desde CDMX Y EDOMEX">
    
    <header class="fixed top-0 left-0 w-full z-50 bg-zinc-950/90 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="#" class="flex items-center gap-3 group">
            <img src="/images/logo-lg.webp" alt="LG Viajes Logo" class="h-10 w-auto object-contain drop-shadow-[0_0_8px_rgba(225,29,72,0.4)]" />
            <div class="flex flex-col">
                <span class="text-white text-2xl font-black italic uppercase leading-none tracking-tighter">
                    LG <span class="text-rose-600">Viajes</span>
                </span>
                <span class="text-[9px] text-zinc-500 tracking-[0.3em] uppercase font-bold ml-1 mt-1">CDMX Y EDOMEX</span>
            </div>
        </a>

        <nav class="hidden md:flex items-center gap-10">
            <a href="#inicio" class="text-zinc-400 hover:text-white transition-colors text-xs uppercase tracking-[0.2em] font-bold">Inicio</a>
            <a href="#beneficios" class="text-zinc-400 hover:text-white transition-colors text-xs uppercase tracking-[0.2em] font-bold">Beneficios</a>
            <a href="#servicios" class="text-zinc-400 hover:text-white transition-colors text-xs uppercase tracking-[0.2em] font-bold">Servicios</a>
            <a href="#contacto" class="bg-rose-600 text-white px-7 py-2.5 rounded-full text-xs uppercase tracking-[0.2em] font-black hover:bg-rose-700 transition-all hover:scale-105 shadow-lg shadow-rose-900/20">
                Cotizar
            </a>
        </nav>

        <button id="menu-btn" class="md:hidden text-white text-2xl focus:outline-none">
            <i class="fa-solid fa-bars-staggered text-rose-600"></i>
        </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden bg-zinc-900 border-b border-white/5 px-6 py-8 space-y-6">
        <a href="#inicio" class="mobile-link block text-zinc-400 hover:text-white text-sm uppercase tracking-widest font-bold">Inicio</a>
        <a href="#beneficios" class="mobile-link block text-zinc-400 hover:text-white text-sm uppercase tracking-widest font-bold">Beneficios</a>
        <a href="#servicios" class="mobile-link block text-zinc-400 hover:text-white text-sm uppercase tracking-widest font-bold">Servicios</a>
        <a href="#contacto" class="mobile-link block bg-rose-600 text-white text-center py-4 rounded-xl text-xs uppercase tracking-widest font-black">Cotizar Ahora</a>
    </div>
</header>

    <main class="bg-zinc-950">
        <section id="inicio" class="relative h-screen flex items-center px-6 md:px-20 overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img src="/images/hero-bg.webp" class="w-full h-full object-cover opacity-20" alt="Transporte Ejecutivo" />
                <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/80 to-transparent"></div>
            </div>

            <div class="relative z-10 max-w-4xl pt-20">
                <span class="text-rose-600 font-bold tracking-[0.3em] uppercase text-sm mb-4 block italic">Servicio Ejecutivo Personalizado</span>
                <h1 class="text-6xl md:text-8xl font-black text-white leading-[0.9] mb-6 italic uppercase tracking-tighter">
                    Viaja con <br/> <span class="text-rose-600">Seguridad</span>
                </h1>
                <p class="text-xl md:text-2xl text-zinc-400 mb-10 max-w-2xl font-light leading-relaxed">
                    Traslados profesionales en CDMX Y EDOMEX a cualquier punto de la ciudad. Confort, puntualidad y confianza.
                </p>
                <a href="#contacto" class="bg-rose-600 text-white px-10 py-5 rounded-2xl font-black uppercase tracking-widest text-sm inline-flex items-center gap-3 hover:bg-rose-700 transition shadow-[0_15px_30px_rgba(225,29,72,0.3)] transform hover:-translate-y-1">
                    <i class="fa-solid fa-car"></i> Solicitar Cotización
                </a>
            </div>
        </section>

        <section id="beneficios" class="py-24 px-6 bg-zinc-900">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16">
                <div class="flex flex-col items-center text-center">
                    <div class="w-20 h-20 rounded-2xl border border-rose-600/20 flex items-center justify-center mb-8 bg-zinc-950 shadow-xl rotate-3">
                        <i class="fa-solid fa-shield-alt text-rose-600 text-3xl"></i>
                    </div>
                    <h3 class="text-white text-2xl font-black italic uppercase mb-4">Seguridad</h3>
                    <p class="text-zinc-400 text-sm leading-relaxed font-light">Conductores certificados y unidades en perfecto estado mecánico.</p>
                </div>
                <div class="flex flex-col items-center text-center">
                    <div class="w-20 h-20 rounded-2xl border border-rose-600/20 flex items-center justify-center mb-8 bg-zinc-950 shadow-xl -rotate-3">
                        <i class="fa-regular fa-clock text-rose-600 text-3xl"></i>
                    </div>
                    <h3 class="text-white text-2xl font-black italic uppercase mb-4">Puntualidad</h3>
                    <p class="text-zinc-400 text-sm leading-relaxed font-light">Tu tiempo es valioso. Llegamos siempre 5 minutos antes de lo acordado.</p>
                </div>
                <div class="flex flex-col items-center text-center">
                    <div class="w-20 h-20 rounded-2xl border border-rose-600/20 flex items-center justify-center mb-8 bg-zinc-950 shadow-xl rotate-3">
                        <i class="fa-regular fa-star text-rose-600 text-3xl"></i>
                    </div>
                    <h3 class="text-white text-2xl font-black italic uppercase mb-4">Confort</h3>
                    <p class="text-zinc-400 text-sm leading-relaxed font-light">Unidades equipadas para que disfrutes de cada trayecto con total comodidad.</p>
                </div>
            </div>
        </section>

        <section id="servicios" class="py-28 px-6 bg-zinc-950">
            <div class="max-w-7xl mx-auto mb-12 flex flex-col md:flex-row justify-between items-end gap-6">
                <h2 class="text-5xl font-black text-white italic uppercase tracking-tighter leading-none">Nuestros <span class="text-rose-600">Servicios</span></h2>
                <div class="h-[1px] bg-white/10 flex-grow mx-10 hidden md:block mb-3"></div>
            </div>

            <div class="flex overflow-x-auto gap-6 pb-10 snap-x snap-mandatory scrollbar-hide scroll-smooth px-4">
                <div class="min-w-[85%] md:min-w-[380px] bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-white/5 snap-center shadow-2xl group">
                    <div class="h-64 overflow-hidden"><img src="/images/servicio-aeropuerto.webp" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Aeropuerto" /></div>
                    <div class="p-8"><h3 class="text-white text-2xl font-black italic uppercase mb-3 tracking-tight">Aeropuerto</h3><p class="text-zinc-500 text-sm leading-relaxed font-light">Monitoreo de vuelos y bienvenida personalizada.</p></div>
                </div>
                <div class="min-w-[85%] md:min-w-[380px] bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-white/5 snap-center shadow-2xl group">
                    <div class="h-64 overflow-hidden"><img src="/images/servicio-diario.webp" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Locales" /></div>
                    <div class="p-8"><h3 class="text-white text-2xl font-black italic uppercase mb-3 tracking-tight">Viajes Locales</h3><p class="text-zinc-500 text-sm leading-relaxed font-light">Transporte seguro para tu día a día y diligencias.</p></div>
                </div>
                <div class="min-w-[85%] md:min-w-[380px] bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-white/5 snap-center shadow-2xl group">
                    <div class="h-64 overflow-hidden"><img src="/images/servicio-familiar.webp" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Familiar" /></div>
                    <div class="p-8"><h3 class="text-white text-2xl font-black italic uppercase mb-3 tracking-tight">Salidas Familiares</h3><p class="text-zinc-500 text-sm leading-relaxed font-light">Espacio y seguridad para los que más quieres.</p></div>
                </div>
                <div class="min-w-[85%] md:min-w-[380px] bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-white/5 snap-center shadow-2xl group">
                    <div class="h-64 overflow-hidden"><img src="/images/servicio-trabajo.webp" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Trabajo" /></div>
                    <div class="p-8"><h3 class="text-white text-2xl font-black italic uppercase mb-3 tracking-tight">Diarios de Trabajo</h3><p class="text-zinc-500 text-sm leading-relaxed font-light">Puntualidad para tus traslados recurrentes a la oficina.</p></div>
                </div>
                <div class="min-w-[85%] md:min-w-[380px] bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-white/5 snap-center shadow-2xl group">
                    <div class="h-64 overflow-hidden"><img src="/images/servicio-ejecutivo.webp" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Ejecutivo" /></div>
                    <div class="p-8"><h3 class="text-white text-2xl font-black italic uppercase mb-3 tracking-tight">Viajes Ejecutivos</h3><p class="text-zinc-500 text-sm leading-relaxed font-light">Privacidad y confort para sus traslados de negocios.</p></div>
                </div>
                <div class="min-w-[85%] md:min-w-[380px] bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-white/5 snap-center shadow-2xl group">
                    <div class="h-64 overflow-hidden"><img src="/images/servicio-eventos.webp" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="Eventos" /></div>
                    <div class="p-8"><h3 class="text-white text-2xl font-black italic uppercase mb-3 tracking-tight">Eventos Especiales</h3><p class="text-zinc-500 text-sm leading-relaxed font-light">Bodas y celebraciones con el toque de distinción merecido.</p></div>
                </div>
            </div>

            <div class="hidden md:flex justify-end gap-4 mt-6 max-w-7xl mx-auto px-6">
                <button onclick="document.querySelector('.scrollbar-hide').scrollBy({left: -400, behavior: 'smooth'})" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-rose-600 transition cursor-pointer"><i class="fa-solid fa-chevron-left"></i></button>
                <button onclick="document.querySelector('.scrollbar-hide').scrollBy({left: 400, behavior: 'smooth'})" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-rose-600 transition cursor-pointer"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </section>

        <section id="contacto" class="py-28 px-6 bg-zinc-900">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
                <div>
                    <h2 class="text-6xl font-black text-white italic uppercase mb-7 tracking-tighter leading-none">Solicite su <br/> <span class="text-rose-600">Cotización</span></h2>
                    <p class="text-zinc-400 text-xl font-light mb-12 leading-relaxed">Complete el formulario y reciba su tarifa personalizada por WhatsApp.</p>
                    <div class="space-y-6 text-zinc-300">
                        <div class="flex items-center gap-5 italic uppercase font-bold text-sm tracking-widest"><i class="fa-solid fa-location-dot text-rose-600 text-xl"></i><span>CDMX Y TODA EL AREA METROPOLITANA</span></div>
                        <div class="flex items-center gap-5 italic uppercase font-bold text-sm tracking-widest"><i class="fa-regular fa-clock text-rose-600 text-xl"></i><span>Disponibilidad 24/7</span></div>
                    </div>
                </div>

                <div class="bg-zinc-950 p-10 rounded-[2.5rem] border border-white/5 shadow-2xl">
                    <form id="cotizacionForm" class="space-y-6">
                        <div>
                            <label class="block text-zinc-500 text-xs font-black uppercase mb-2 ml-1 tracking-widest">Nombre Completo</label>
                            <input type="text" id="nombre" required class="w-full bg-zinc-900 border border-white/5 rounded-xl px-5 py-4 text-white focus:border-rose-600 outline-none transition" placeholder="¿Cómo te llamas?" />
                        </div>
                        <div>
                            <label class="block text-zinc-500 text-xs font-black uppercase mb-2 ml-1 tracking-widest">Origen</label>
                            <input type="text" id="origen" required class="w-full bg-zinc-900 border border-white/5 rounded-xl px-5 py-4 text-white focus:border-rose-600 outline-none transition" placeholder="Punto de partida" />
                        </div>
                        <div>
                            <label class="block text-zinc-500 text-xs font-black uppercase mb-2 ml-1 tracking-widest">Destino</label>
                            <input type="text" id="destino" required class="w-full bg-zinc-900 border border-white/5 rounded-xl px-5 py-4 text-white focus:border-rose-600 outline-none transition" placeholder="Punto de llegada" />
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <input type="date" id="fecha" required class="w-full bg-zinc-900 border border-white/5 rounded-xl px-5 py-4 text-white focus:border-rose-600 outline-none [color-scheme:dark]" />
                            <input type="time" id="hora" required class="w-full bg-zinc-900 border border-white/5 rounded-xl px-5 py-4 text-white focus:border-rose-600 outline-none [color-scheme:dark]" />
                        </div>
                        <button type="submit" class="w-full bg-rose-600 text-white font-black italic uppercase py-5 rounded-2xl flex items-center justify-center gap-3 hover:bg-rose-700 transition shadow-lg shadow-rose-900/20 transform hover:-translate-y-1">
                            <i class="fa-brands fa-whatsapp text-xl"></i> Cotizar por WhatsApp
                        </button>
                    </form>
                </div>
            </div>
        </section>

        <footer class="py-16 px-6 bg-zinc-950 border-t border-white/5 text-center">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8 mb-12">
                
                <div class="flex items-center gap-3">
                    <img src="/images/logo-lg.webp" alt="LG Viajes Logo" class="h-8 w-auto object-contain opacity-80" />
                    <div class="flex flex-col text-left">
                        <span class="text-rose-600 font-black text-xl italic uppercase tracking-tighter leading-none">LG <span class="text-white">Viajes</span></span>
                        <span class="text-[8px] text-zinc-600 tracking-[0.2em] font-bold uppercase">CDMX Y EDOMEX</span>
                    </div>
                </div>

                <div class="flex justify-center gap-10 text-zinc-400 text-sm font-bold uppercase tracking-widest">
                    <a href="#" class="hover:text-rose-600 transition">WhatsApp</a>
                    <a href="#" class="hover:text-rose-600 transition">Facebook</a>
                    <a href="#" class="hover:text-rose-600 transition">Instagram</a>
                </div>
                <a href="#" class="text-zinc-600 text-xs hover:text-zinc-400 transition uppercase tracking-widest">Aviso de Privacidad</a>
            </div>
            <p class="text-zinc-700 text-[10px] font-bold uppercase tracking-[0.3em]">© 2026 LG Viajes. Transporte Seguro y de Confianza.</p>
        </footer>
    </main>

    <script>
        const slider = document.querySelector('.scrollbar-hide');
        let isPaused = false;
        function startAutoScroll() {
            setInterval(() => {
                if (!isPaused && slider) {
                    const isAtEnd = slider.scrollLeft + slider.offsetWidth >= slider.scrollWidth - 10;
                    if (isAtEnd) { slider.scrollTo({ left: 0, behavior: 'smooth' }); } 
                    else { slider.scrollBy({ left: 400, behavior: 'smooth' }); }
                }
            }, 4000);
        }
        slider?.addEventListener('mouseenter', () => isPaused = true);
        slider?.addEventListener('mouseleave', () => isPaused = false);
        startAutoScroll();

// LÓGICA WHATSAPP - VERSIÓN DEFINITIVA PARA EMOJIS
        const form = document.getElementById('cotizacionForm') as HTMLFormElement;
        form?.addEventListener('submit', (e) => {
            e.preventDefault();
            const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
            const origen = (document.getElementById('origen') as HTMLInputElement).value;
            const destino = (document.getElementById('destino') as HTMLInputElement).value;
            const fecha = (document.getElementById('fecha') as HTMLInputElement).value;
            const hora = (document.getElementById('hora') as HTMLInputElement).value;
            
            const telefono = "525574163390"; 

            // Redactamos el texto con emojis normales
            const textoNatural = `Hola, ¿qué tal? 👋 Me gustaría solicitar una cotización para un traslado con *LG Viajes*. 

Le comparto los detalles de mi viaje: 

👤 *Nombre:* ${nombre}
📍 *Origen:* ${origen}
🏁 *Destino:* ${destino}
📅 *Fecha:* ${fecha}
⏰ *Hora:* ${hora}

¿Me podrían confirmar disponibilidad y costo? Quedo al pendiente, muchas gracias.`;

            // La clave es aplicar encodeURIComponent a TODO el bloque de texto junto
            const mensajeFinal = encodeURIComponent(textoNatural);
            
            // Usamos api.whatsapp.com que suele ser más amigable con los emojis en PC
            window.open(`https://api.whatsapp.com/send?phone=${telefono}&text=${mensajeFinal}`, '_blank');
        });
		// Lógica para el Menú Móvil
const menuBtn = document.getElementById('menu-btn');
const mobileMenu = document.getElementById('mobile-menu');
const mobileLinks = document.querySelectorAll('.mobile-link');

// Abrir/Cerrar al dar clic al botón
menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
});

// Cerrar el menú automáticamente al hacer clic en un enlace (para que baje a la sección)
mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
    });
});
    </script>
</Layout>

<style is:global>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    html { scroll-behavior: smooth; }
</style>